          "name": "buscar Berries",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// No início do script ou no Pre-request Script\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "// Isso garante que a variável global sempre seja igual ao que a API retornou\r",
                  "pm.globals.set(\"berry_name\", jsonData.name); \r",
                  "\r",
                  "pm.test(\"Body contains name validation\", function () {\r",
                  "    var nameFromResponse = jsonData.name;\r",
                  "    // Agora isso sempre será verdadeiro\r",
                  "    pm.expect(nameFromResponse).to.eql(pm.globals.get(\"berry_name\"));\r",
                  "});\r",
                  "\r",
                  "pm.globals.clear();\r",
                  "\r",
                  "/*\r",
                  "pm.test(\"Body contains the berry name\", function () {\r",
                  "    var name = pm.response.json().name\r",
                  "    console.log(name);\r",
                  "    pm.expect(name).to.include(pm.globals.get(\"berry_name\"))\r",
                  "\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Body contains name validation\", function () {\r",
                  "   // acessar o campo 'name' do json\r",
                  "   var jsonData = pm.response.json(); // guardando o json em uma variável\r",
                  "   var nameFromResponse = jsonData.name; // acessando o campo 'name' do json\r",
                  "    console.log(\"Nome da resposta \" + nameFromResponse);\r",
                  "\r",
                  "    pm.expect(nameFromResponse).to.eql(pm.globals.get(\"berry_name\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Body contains firmness validation\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    // Exemplo para Cheri, a firmeza é \"soft\"\r",
                  "    pm.expect(jsonData.firmness.name).to.not.be.undefined;\r",
                  "    console.log(\"Firmeza: \" + jsonData.firmness.name);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Body tem a string\", function(){\r",
                  "    pm.expect(pm.response.text()).to.include(\"hard\");\r",
                  "})\r",
                  "\r",
                  "\r",
                  "pm.test(\"Response body contains string\", function(){\r",
                  "    pm.expect(pm.response.text()).to.include(\"cheri\");\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Capturar os resultados de uma berry\",function(){\r",
                  "    var berry_name = pm.response.json().results;\r",
                  "    console.log(berry_name)\r",
                  "    pm.globals.set(\"berry_name\", berry_name[3].name)\r",
                  "})*/"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
